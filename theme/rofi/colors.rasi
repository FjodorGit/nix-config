/* Catppuccin Mocha */
* {
    background:     #1e1e2eFF; /* base */
    background-alt: #313244FF; /* surface0 */
    foreground:     #cdd6f4FF; /* text */
    selected:       #89b4faFF; /* blue */
    active:         #a6e3a1FF; /* green */
    urgent:         #f38ba8FF; /* red */
}
